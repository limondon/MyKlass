rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Только авторизованный admin читает/пишет всё
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Родители читают ученика по токену (без авторизации)
    match /students/{id} {
      allow read: if true;
    }

    // Родители читают группы, абонементы, события (публично)
    match /groups/{id} {
      allow read: if true;
    }
    match /subscriptions/{id} {
      allow read: if true;
    }
    match /events/{id} {
      allow read: if true;
    }
  }
}
